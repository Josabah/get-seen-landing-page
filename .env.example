# Required: PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# Server port (default: 3000)
PORT=3000

# CORS allowed origin for API requests (default: http://localhost:3000)
# ALLOWED_ORIGIN=http://localhost:3000

# Optional: API origin injected into the frontend when served from Express (empty = same origin)
# API_BASE=